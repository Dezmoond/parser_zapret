# Скопируйте в .env и укажите путь к папке с моделью на вашем ПК.
# Для docker compose: модель будет смонтирована в контейнер как /model.

# Windows (слеши можно и / и \)
MODEL_HOST_PATH=H:/anaconda/Lama5/Lama5/Llama-3.2-3B-Instruct

# Если модель на другом диске, например:
# MODEL_HOST_PATH=C:/models/Llama-3.2-3B-Instruct
